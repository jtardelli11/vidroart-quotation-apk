{
  "appId": "com.vidroart.orcamentos",
  "appName": "VIDROART Orçamentos",
  "webDir": "www",
  "server": {
    "url": "https://jtardelli11.github.io/vidroart-quotation-html/",
    "cleartext": false,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0f1512"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#0f1512",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0f1512"
    }
  }
} 
 
